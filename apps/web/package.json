{
  "name": "@rahul-portfolio/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "netlify dev",
    "client": "vite",
    "server": "node api/server.js",
    "build": "vite build && pnpm run build:functions",
    "build:functions": "cd netlify/functions && pnpm install",
    "preview": "vite preview",
    "generate-pdf": "bash scripts/install_latex.sh && node generate_resume_pdf.cjs",
    "build:css": "postcss src/assets/tailwind.css -o src/assets/main.css",
    "watch:css": "postcss src/assets/tailwind.css -o src/assets/main.css",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.4.0",
    "axios": "^1.8.3",
    "buffer": "^6.0.3",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "emailjs-com": "^2.6.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "framer-motion": "^12.5.0",
    "js-yaml": "^4.1.1",
    "node-cache": "^5.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.43.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^7.2.2",
    "react-router-dom": "^6.30.3",
    "react-scroll": "^1.8.1",
    "react-twitter-embed": "^4.0.4",
    "redux": "^4.0.5",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "serverless-http": "^3.2.0",
    "styled-components": "^6.1.16",
    "twitter-api-sdk": "^1.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^24.1.3",
    "netlify-cli": "^24.4.0",
    "postcss": "^8.4.31",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.3.5",
    "vite": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
